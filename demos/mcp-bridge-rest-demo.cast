[0.087, "o", "\r\n\u001b[1m\u001b[36m==>\u001b[0m Demo configuration\r\nBase URL: \u001b[1mhttp://localhost:8000\u001b[0m\r\nLLM provider: \u001b[1mollama\u001b[0m\r\nLLM model: \u001b[1mllama3.2:latest\u001b[0m\r\nFilesystem root: \u001b[1m/Users/roberto/mcp-bridge/examples/demo/sample-files\u001b[0m\r\nSync query timeout: \u001b[1m120s\u001b[0m\r\nMCP server: \u001b[1mnpx -y @modelcontextprotocol/server-filesystem /Users/roberto/mcp-bridge/examples/demo/sample-files\u001b[0m\r\n\r\n\u001b[1m\u001b[36m==>\u001b[0m Health check\r\n"]
