# API Configuration
API_TITLE="mcp-bridge"
API_DESCRIPTION="REST bridge for MCP capabilities with session-scoped guardrails, powered by mcp-use."
API_VERSION="0.2.0"

# Server Settings
HOST="0.0.0.0"
PORT=8000
DEBUG=false

# CORS Settings
# Default is localhost-only for safer public defaults.
# For permissive local/dev access, set: CORS_ORIGINS='["*"]'
CORS_ORIGINS='["http://localhost","https://localhost","http://127.0.0.1","https://127.0.0.1","http://[::1]","https://[::1]","http://localhost:3000","https://localhost:3000","http://127.0.0.1:3000","https://127.0.0.1:3000","http://[::1]:3000","https://[::1]:3000","http://localhost:5173","https://localhost:5173","http://127.0.0.1:5173","https://127.0.0.1:5173","http://[::1]:5173","https://[::1]:5173","http://localhost:8000","https://localhost:8000","http://127.0.0.1:8000","https://127.0.0.1:8000","http://[::1]:8000","https://[::1]:8000"]'

# Session Management
MAX_ACTIVE_SESSIONS=100
SESSION_TIMEOUT=3600

# Logging
LOG_LEVEL="INFO"

# LLM Provider API Keys
OPENAI_API_KEY="your_openai_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Langfuse Observability (optional, auto-detected by mcp-use when installed)
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="http://127.0.0.1:3000"

# E2B Sandbox (optional)
E2B_API_KEY="your_e2b_api_key_here"
DEFAULT_SANDBOX_TEMPLATE="base"

# Ollama Settings (if using Ollama)
OLLAMA_BASE_URL="http://localhost:11434"
